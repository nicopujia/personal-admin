#!/bin/sh
set -eu

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
app_dir="$(CDPATH= cd -- "$script_dir/.." && pwd)"
source_unit="$app_dir/ops/systemd/pujia-admin.service"
target_dir="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
target_unit="$target_dir/pujia-admin.service"

if [ ! -f "$app_dir/.env" ]; then
  echo "Missing .env in project root: $app_dir/.env" >&2
  exit 1
fi

mkdir -p "$target_dir"

escaped_app_dir="$(printf '%s' "$app_dir" | sed 's/[&|\\]/\\&/g')"
sed "s|__APP_DIR__|$escaped_app_dir|g" "$source_unit" > "$target_unit"

systemctl --user daemon-reload
systemctl --user enable pujia-admin.service >/dev/null

echo "Installed $target_unit"
